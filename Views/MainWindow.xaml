<Window
    x:Class="DigtialScreen.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DigtialScreen.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
    xmlns:b="clr-namespace:DigtialScreen.Base"
    xmlns:zxc="clr-namespace:DigtialScreen.Controls"
    Width="1400"
    Height="750"
    mc:Ignorable="d"
    AllowsTransparency="True"
    FontFamily="Microsoft Yahei"
    FontWeight="ExtraLight"
    ResizeMode="CanResizeWithGrip"
    Title="数字监控Demo"
    WindowStartupLocation="Manual"
    WindowStyle="None">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="AUTO" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Foreground="Black" Text="{TemplateBinding Header}" />
                                <TextBlock Foreground="White" Margin="10,0,0,0" Text="{TemplateBinding Tag}" />
                            </StackPanel>

                            <Border Grid.Row="1" BorderThickness="1" BorderBrush="#447D96C4"
                                    Margin="0,7,5,5">
                                <ContentPresenter/>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,7,0,0">
                                <Border BorderBrush="#447D96C4" BorderThickness="0,0,1,1" Margin="5,5,0,0" />
                                <Line X1="0" Y1="0" X2="5" Y2="0" Stroke="#447D96C4" StrokeThickness="1"
                                      HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,0,0" />
                                <Line X1="0" Y1="0" X2="0" Y2="5" Stroke="#447D96C4" StrokeThickness="1"
                                      HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="5,0,0,0" />
                                <Polyline Points="5,0 0,0 0,5" Stroke="#7D96C4" VerticalAlignment="Top"
                                       HorizontalAlignment="Left" />
                                <Polyline Points="0,0 5,0 5,5" Stroke="#7D96C4" VerticalAlignment="Top"
                                       HorizontalAlignment="Right" Margin="0,0,5,0" />
                                <Polyline Points="0,5 5,5 5,0" Stroke="#7D96C4" VerticalAlignment="Bottom"
                                       HorizontalAlignment="Right" Margin="0,0,5,5" />
                                <Polyline Points="0,0 0,5 5,5" Stroke="#7D96C4" VerticalAlignment="Bottom"
                                       HorizontalAlignment="Left" Margin="0,0,0,5" />
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#a1c4fd" />
                <GradientStop Offset="0.5" Color="#8fd3f4" />
                <GradientStop Offset="1" Color="#c2e9fb" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!-- 顶部栏背景（深色渐变） -->
        <Border Grid.Row="0" CornerRadius="0 0 20 20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#2C3E50" />
                    <GradientStop Offset="0.7" Color="#3a4a5a" />
                    <GradientStop Offset="1" Color="#4a5a6a" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- 凸起的中间部分 - 使用和背景一致的渐变 -->
        <Border
            Width="200"
            Height="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadius="10 10 10 10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#4a5a6a" />
                    <GradientStop Offset="0.5" Color="#3a4a5a" />
                    <GradientStop Offset="1" Color="#a1c4fd" />
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="20"
                FontWeight="Bold"
                Foreground="White"
                Text="气密性测试舱" />
        </Border>


        <TextBlock
            Margin="10,0,0,0"
            VerticalAlignment="Center"
            FontFamily="../Assets/Fonts/#iconfont"
            FontSize="17"
            Foreground="White"
            Text="&#xe61d;" />
        <TextBlock
            Margin="30,0,0,0"
            VerticalAlignment="Center"
            Foreground="White"
            Text="{Binding TimeCnFormat}" />

        <StackPanel
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            TextBlock.Foreground="LightSkyBlue">
            <TextBlock
                VerticalAlignment="Center"
                FontFamily="../Assets/Fonts/#iconfont"
                FontSize="13"
                Text="&#xe6bd;" />
            <TextBlock Text="室内湿度" />
            <TextBlock
                Margin="0,0,10,0"
                VerticalAlignment="Center"
                FontSize="10"
                Text="0℃" />
            <TextBlock
                VerticalAlignment="Center"
                FontFamily="../Assets/Fonts/#iconfont"
                Text="&#xe610;" />
            <TextBlock Text="室内湿度" />
            <TextBlock
                Margin="0,0,20,0"
                VerticalAlignment="Center"
                FontSize="10"
                Text="55%" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="1.8*" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <UniformGrid Margin="20,15" Columns="1">
                <GroupBox Header="测试状态" Tag="Equipment Inspection">
                    <GroupBox.Resources>
                        <Style TargetType="lvc:PieSeries">
                            <Setter Property="DataLabels" Value="True" />
                            <Setter Property="LabelPosition" Value="OutsideSlice" />
                            <Setter Property="StrokeThickness" Value="0" />
                            <Setter Property="DataLabelsTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <StackPanel TextBlock.Foreground="Black">
                                            <TextBlock Text="{Binding Point.Y, StringFormat={}{0:P1}}" />
                                            <TextBlock Text="{Binding Point.SeriesView.Title}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupBox.Resources>
                    <lvc:PieChart InnerRadius="40" Width="110" Height="110"
                  DisableAnimations="True" StartingRotationAngle="0"
                  HoverPushOut="0"  Series="{Binding StateSeries}">
                    </lvc:PieChart>
                </GroupBox>
                <GroupBox Header="测试人员绩效">
                    <Grid Margin="5,3,10,3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20" />
                            <RowDefinition />
                            <RowDefinition Height="25" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border Width="8" Height="8" Background="DarkCyan" Margin="3,0" />
                            <TextBlock Text="计划测试量" Foreground="DarkBlue" FontSize="9" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <Border Width="8" Height="8" Background="DarkRed" Margin="3,0" />
                            <TextBlock Text="实际完成量" Foreground="DarkBlue" FontSize="9" VerticalAlignment="Center" Margin="0,0,10,0" />
                        </StackPanel>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding WorkerCompareList}"
                                      TextBlock.Foreground="DarkBlue" TextBlock.FontSize="10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="25" />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="2" Margin="0,0,20,0" Name="bor" />
                                        <TextBlock Text="{Binding Name}" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <Border BorderBrush="#162731" BorderThickness="0,1,0,0"
                                                VerticalAlignment="Center" Grid.Column="1" />
                                        <Polygon Points="4,0 0,7,4, 14 8,14 8,0" Fill="#162731" Grid.Column="1"
                                                 VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="3,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="DarkCyan" Height="5" HorizontalAlignment="Left" Grid.Column="2" >
                                                    <Border.Width>
                                                        <MultiBinding>
                                                            <MultiBinding.Converter>
                                                                <b:CompareValueConvert />
                                                            </MultiBinding.Converter>
                                                            <Binding Path="PlanValue" />
                                                            <Binding ElementName="bor" Path="ActualWidth" />
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                                <TextBlock Text="{Binding PlanValue}" FontSize="8"
                                                               VerticalAlignment="Center" Margin="5,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="3,0,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="DarkRed" Height="5" HorizontalAlignment="Left" Grid.Column="2" >
                                                        <Border.Width>
                                                            <MultiBinding>
                                                                <MultiBinding.Converter>
                                                                    <b:CompareValueConvert />
                                                                </MultiBinding.Converter>
                                                                <Binding Path="FinishedValue" />
                                                                <Binding ElementName="bor" Path="ActualWidth" />
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                    <TextBlock Text="{Binding FinishedValue}" FontSize="8"
                       VerticalAlignment="Center" Margin="5,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="75" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="#162731" BorderThickness="0,0,0,1" VerticalAlignment="Top"
                                    Grid.Column="1" Margin="0,5,0,0" />
                            <UniformGrid Rows="1" TextBlock.Foreground="#162731" Grid.Column="1"
                                         TextBlock.FontSize="9" VerticalAlignment="Center" >
                                <TextBlock Text="0" />
                                <TextBlock Text="48" />
                                <TextBlock Text="96" />
                                <TextBlock Text="144" />
                                <TextBlock Text="192" />
                                <TextBlock Text="240" />
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </GroupBox>
                <GroupBox Header="报警信息"  Tag="Alarms information">
                    <ItemsControl ItemsSource="{Binding Alarms}"
                                  TextBlock.Foreground="Black"
                                  TextBlock.LineHeight="23"
                                  Margin="3,5,5,5"
                                  ></ItemsControl>
                </GroupBox>
            </UniformGrid>
            <Grid Grid.Column="1" Margin="0,40,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="110" />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                
                <TextBlock Foreground="LightYellow" FontSize="17" VerticalAlignment="Top">
                    <Run Text="当日测试量" />
                </TextBlock>
                <ItemsControl VerticalAlignment="Center" TextBlock.Foreground="White"
                              TextBlock.FontSize="30" Margin="0,30,0,0"
                              ItemsSource="{Binding CurrentYeild}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Padding="0,10" Background="#9096BF" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Margin="2,0" Width="20" TextAlignment="Center" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,0,0">
                        <TextBlock Text="计划测试量" Foreground="#0a2639" FontSize="12" Margin="0,5" HorizontalAlignment="Center" />
                    <TextBlock Text="19600" Foreground="#CC2BB6FF" FontSize="20" HorizontalAlignment="Center" />
                </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="完成度" Foreground="#0a2639" FontSize="12" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding FinishedRate,StringFormat=\{0\}%}" Foreground="PaleVioletRed" HorizontalAlignment="Center"
                                   Margin="10,0" FontSize="20"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <TextBlock Text="关键密封合格率" Foreground="#0a2639" FontSize="12" />
                        <zxc:CircularProgressBar Value="0.75" Foreground="#db3444" BackColor="#11FFFFFF"
                            Width="55" Height="55" Margin="0,18,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                        <TextBlock Text="常规密封合格率" Foreground="#0a2639" FontSize="12" />
                        <zxc:CircularProgressBar Value="0.75" Foreground="#db3444" BackColor="#11FFFFFF"
                             Width="55" Height="55" Margin="0,18,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                        <TextBlock Text="功能性密封合格率" Foreground="#0a2639" FontSize="12" />
                        <zxc:CircularProgressBar Value="0.75" Foreground="#db3444" BackColor="#11FFFFFF"
                             Width="55" Height="55" Margin="0,18,0,0" />
                    </StackPanel>
                </Grid>

                <GroupBox Header="测试量/合格率统计" Tag="Test Statistics" Grid.Row="1">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20" />
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <Border Width="8" Height="8" Background="DarkCyan" Margin="3,0" />
                            <TextBlock Text="每日测试总量" Foreground="DarkBlue" FontSize="9" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <Border Width="8" Height="8" Background="DarkRed" Margin="3,0" />
                            <TextBlock Text="平均测试合格率" Foreground="DarkBlue" FontSize="9" VerticalAlignment="Center" Margin="0,0,10,0" />
                        </StackPanel>

                        <lvc:CartesianChart Grid.Row="1" DisableAnimations="True">
                            <lvc:CartesianChart.Series>
                                <lvc:LineSeries Values="{Binding YieldValue1}" LineSmoothness="0" Stroke="IndianRed" Fill="Transparent" />
                                <lvc:LineSeries Values="{Binding YieldValue2}" LineSmoothness="0" Stroke="Black">
                                    <lvc:LineSeries.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#882BB6FE" Offset="0" />
                                            <GradientStop Color="#442bb6fe" Offset="0.2" />
                                            <GradientStop Color="#112bb6fe" Offset="1" />
                                        </LinearGradientBrush>
                                    </lvc:LineSeries.Fill>
                                </lvc:LineSeries>
                            </lvc:CartesianChart.Series>
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="01/01,02/01,03/02,04/02,05/02,06/02,07/02,08/02,09/02,10/02,11/02,12/02"
                                          Foreground="#0a2639" >
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="1" StrokeThickness="0" />
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                        </lvc:CartesianChart>
                    </Grid>
                </GroupBox>
                <GroupBox Header="测试量统计" Tag="Test Volume Statistics" Grid.Row="2">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20" />
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <Border Width="8" Height="8" Background="#2BB6FE" Margin="3,0" />
                            <TextBlock Text="关键密封测试" Foreground="DarkBlue" FontSize="9" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <Border Width="8" Height="8" Background="#808080" Margin="3,0" />
                            <TextBlock Text="常规密封测试" Foreground="DarkBlue" FontSize="9" VerticalAlignment="Center" Margin="0,0,10,0" />
                        </StackPanel>

                        <lvc:CartesianChart Grid.Row="1" DisableAnimations="True" Series="{Binding BarChartSeries}">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="周一,周二,周三,周四,周五,周六,周日"
                                          Foreground="#0a2639" >
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="1" StrokeThickness="0" />
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                        </lvc:CartesianChart>
                    </Grid>
                </GroupBox>
            </Grid>


            <Grid Grid.Column="2" Margin="20,15">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="1.2*" />
                </Grid.RowDefinitions>

                <GroupBox Header="测试不良指标" Tag="Poor Test Indicators">
                    <ItemsControl ItemsSource="{Binding BadScatter}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Grid />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <zxc:CircularProgressBar Value="{Binding Value}" 
                                                         Width="{Binding Size}" 
                                                         Height="{Binding Size}"
                                                         Title="{Binding Title}"
                                                         Foreground="Transparent"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>

                <GroupBox Header="测试质量控制" Tag="Test Quality Control" Grid.Row="1" >
                    <Grid Margin="5,3,10,3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20" />
                            <RowDefinition />
                            <RowDefinition Height="25" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border Width="8" Height="8" Background="DarkCyan" Margin="3,0" />
                            <TextBlock Text="计划校准次数" Foreground="DarkBlue" FontSize="9" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <Border Width="8" Height="8" Background="DarkRed" Margin="3,0" />
                            <TextBlock Text="实际校准次数" Foreground="DarkBlue" FontSize="9" VerticalAlignment="Center" Margin="0,0,10,0" />
                        </StackPanel>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding QualityList}"
                  TextBlock.Foreground="DarkBlue" TextBlock.FontSize="10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="25" />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="2" Margin="0,0,20,0" Name="bor" />
                                        <TextBlock Text="{Binding Name}" HorizontalAlignment="Right"
                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <Border BorderBrush="#162731" BorderThickness="0,1,0,0"
                            VerticalAlignment="Center" Grid.Column="1" />
                                        <Polygon Points="4,0 0,7,4, 14 8,14 8,0" Fill="#162731" Grid.Column="1"
                             VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="3,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="DarkCyan" Height="5" HorizontalAlignment="Left" Grid.Column="2" >
                                                    <Border.Width>
                                                        <MultiBinding>
                                                            <MultiBinding.Converter>
                                                                <b:CompareValueConvert />
                                                            </MultiBinding.Converter>
                                                            <Binding Path="PlanValue" />
                                                            <Binding ElementName="bor" Path="ActualWidth" />
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                                <TextBlock Text="{Binding PlanValue}" FontSize="8"
                                           VerticalAlignment="Center" Margin="5,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="3,0,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="DarkRed" Height="5" HorizontalAlignment="Left" Grid.Column="2" >
                                                        <Border.Width>
                                                            <MultiBinding>
                                                                <MultiBinding.Converter>
                                                                    <b:CompareValueConvert />
                                                                </MultiBinding.Converter>
                                                                <Binding Path="FinishedValue" />
                                                                <Binding ElementName="bor" Path="ActualWidth" />
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                    <TextBlock Text="{Binding FinishedValue}" FontSize="8"
   VerticalAlignment="Center" Margin="5,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="75" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="#162731" BorderThickness="0,0,0,1" VerticalAlignment="Top"
                Grid.Column="1" Margin="0,5,0,0" />
                            <UniformGrid Rows="1" TextBlock.Foreground="#162731" Grid.Column="1"
                     TextBlock.FontSize="9" VerticalAlignment="Center" >
                                <TextBlock Text="0" />
                                <TextBlock Text="48" />
                                <TextBlock Text="96" />
                                <TextBlock Text="144" />
                                <TextBlock Text="192" />
                                <TextBlock Text="240" />
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </GroupBox>
            </Grid>

            
        </Grid>
        </Grid>
    </Window>